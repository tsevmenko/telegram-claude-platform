{
  "_comment": "user-gateway config with three client agents (leto, coder, writer). Each gets its own Telegram bot and workspace.",
  "poll_interval_sec": 2,
  "allowed_user_ids": [123456789],
  "allowed_group_ids": [-1001234567890],
  "state_dir": "/home/agent/gateway/state",
  "logs_dir": "/home/agent/gateway/logs",
  "groq_api_key_file": "/home/agent/secrets/groq.key",
  "voice_language": "en",
  "l4": {
    "enabled": true,
    "url": "http://127.0.0.1:1933",
    "api_key_file": "/home/agent/secrets/openviking.key",
    "account": "default"
  },
  "webhook": {
    "enabled": true,
    "listen_host": "0.0.0.0",
    "listen_port": 8080,
    "token_file": "/home/agent/secrets/webhook-token.txt"
  },
  "agents": {
    "leto": {
      "enabled": true,
      "bot_token_file": "/home/agent/secrets/leto-bot-token",
      "bot_username": "your_leto_bot",
      "workspace": "/home/agent/.claude-lab/leto/.claude",
      "model": "opus",
      "timeout_sec": 300,
      "streaming_mode_private": "progress",
      "streaming_mode_group": "partial",
      "system_reminder": "You are Leto, the operator's primary work agent. Be concise.",
      "agent_names": ["leto"],
      "topic_routing": {"-1001234567890": ["1"]},
      "bypass_permissions": true
    },
    "coder": {
      "enabled": true,
      "bot_token_file": "/home/agent/secrets/coder-bot-token",
      "bot_username": "your_coder_bot",
      "workspace": "/home/agent/.claude-lab/coder/.claude",
      "model": "opus",
      "timeout_sec": 600,
      "streaming_mode_private": "progress",
      "streaming_mode_group": "partial",
      "system_reminder": "You are a senior backend engineer. Default stack: Python + asyncio. Code first, explanation after.",
      "agent_names": ["coder"],
      "topic_routing": {"-1001234567890": ["42"]},
      "bypass_permissions": true
    },
    "writer": {
      "enabled": true,
      "bot_token_file": "/home/agent/secrets/writer-bot-token",
      "bot_username": "your_writer_bot",
      "workspace": "/home/agent/.claude-lab/writer/.claude",
      "model": "sonnet",
      "timeout_sec": 300,
      "streaming_mode_private": "off",
      "streaming_mode_group": "off",
      "system_reminder": "You are a precise editor. Improve clarity, cut filler, preserve meaning.",
      "agent_names": ["writer"],
      "topic_routing": {"-1001234567890": ["77"]},
      "bypass_permissions": true
    }
  }
}
