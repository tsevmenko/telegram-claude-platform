{
  "env": {
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "400000"
  },
  "permissions": {
    "allow": [
      "Bash(npm:*)", "Bash(node:*)", "Bash(git:*)", "Bash(gh:*)",
      "Bash(python3:*)", "Bash(pip3:*)", "Bash(pytest:*)",
      "Bash(cat:*)", "Bash(ls:*)", "Bash(mkdir:*)", "Bash(rm:*)",
      "Bash(chmod:*)", "Bash(chown:*)", "Bash(echo:*)", "Bash(printf:*)",
      "Bash(curl:*)", "Bash(jq:*)",
      "Bash(systemctl:*)", "Bash(journalctl:*)",
      "Read", "Write", "Edit", "Glob", "Grep", "Task", "Skill", "TodoWrite",
      "WebFetch", "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/session-bootstrap.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/auto-recall.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/correction-detector.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/block-dangerous.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/protect-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/activity-logger.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/review-reminder.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/flush-to-openviking.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/compact-notify.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/write-handoff.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/auto-capture.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/close-heartbeat.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
