{
  "env": {
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "400000"
  },
  "permissions": {
    "allow": [
      "Read", "Write", "Edit", "Glob", "Grep", "Task", "Skill", "TodoWrite",
      "WebFetch", "WebSearch",

      "Bash(npm:*)", "Bash(node:*)", "Bash(npx:*)",
      "Bash(git:*)", "Bash(gh:*)",
      "Bash(python3:*)", "Bash(python:*)", "Bash(pip3:*)", "Bash(pip:*)", "Bash(pytest:*)",
      "Bash(uv:*)", "Bash(poetry:*)",

      "Bash(cat:*)", "Bash(less:*)", "Bash(more:*)", "Bash(head:*)", "Bash(tail:*)",
      "Bash(ls:*)", "Bash(stat:*)", "Bash(file:*)", "Bash(realpath:*)", "Bash(readlink:*)",
      "Bash(mkdir:*)", "Bash(rmdir:*)", "Bash(rm:*)",
      "Bash(cp:*)", "Bash(mv:*)", "Bash(ln:*)", "Bash(touch:*)", "Bash(install:*)",
      "Bash(chmod:*)", "Bash(chown:*)", "Bash(chgrp:*)",
      "Bash(echo:*)", "Bash(printf:*)", "Bash(tee:*)",
      "Bash(find:*)", "Bash(locate:*)",
      "Bash(grep:*)", "Bash(rg:*)", "Bash(awk:*)", "Bash(sed:*)", "Bash(cut:*)",
      "Bash(tr:*)", "Bash(sort:*)", "Bash(uniq:*)", "Bash(wc:*)", "Bash(xargs:*)",
      "Bash(jq:*)", "Bash(yq:*)",
      "Bash(diff:*)", "Bash(patch:*)",

      "Bash(tar:*)", "Bash(gzip:*)", "Bash(gunzip:*)", "Bash(zcat:*)", "Bash(zgrep:*)",
      "Bash(zip:*)", "Bash(unzip:*)",
      "Bash(rsync:*)", "Bash(scp:*)", "Bash(ssh:*)",

      "Bash(curl:*)", "Bash(wget:*)",
      "Bash(ping:*)", "Bash(dig:*)", "Bash(host:*)", "Bash(nslookup:*)",
      "Bash(ip:*)", "Bash(ss:*)", "Bash(netstat:*)", "Bash(nc:*)",
      "Bash(openssl:*)", "Bash(ssh-keygen:*)", "Bash(gpg:*)",

      "Bash(ps:*)", "Bash(top:*)", "Bash(htop:*)", "Bash(pgrep:*)", "Bash(pkill:*)",
      "Bash(kill:*)", "Bash(killall:*)",
      "Bash(df:*)", "Bash(du:*)", "Bash(free:*)", "Bash(uptime:*)",
      "Bash(uname:*)", "Bash(lsb_release:*)", "Bash(hostnamectl:*)", "Bash(timedatectl:*)",
      "Bash(date:*)", "Bash(cal:*)",
      "Bash(env:*)", "Bash(which:*)", "Bash(type:*)",

      "Bash(systemctl:*)", "Bash(journalctl:*)", "Bash(loginctl:*)",
      "Bash(systemd-analyze:*)", "Bash(systemd-cgls:*)",
      "Bash(crontab:*)",

      "Bash(apt:*)", "Bash(apt-get:*)", "Bash(apt-cache:*)", "Bash(dpkg:*)",
      "Bash(snap:*)",
      "Bash(add-apt-repository:*)",

      "Bash(sudo:*)",
      "Bash(useradd:*)", "Bash(usermod:*)", "Bash(userdel:*)",
      "Bash(deluser:*)", "Bash(adduser:*)",
      "Bash(passwd:*)", "Bash(visudo:*)",
      "Bash(getent:*)", "Bash(id:*)", "Bash(whoami:*)", "Bash(groups:*)",

      "Bash(ufw:*)", "Bash(iptables:*)", "Bash(nft:*)",
      "Bash(fail2ban-client:*)",
      "Bash(tailscale:*)",
      "Bash(unattended-upgrade:*)", "Bash(needrestart:*)",

      "Bash(mount:*)", "Bash(umount:*)", "Bash(lsblk:*)", "Bash(blkid:*)",
      "Bash(swapon:*)", "Bash(swapoff:*)",

      "Bash(test:*)", "Bash(true)", "Bash(false)", "Bash(sleep:*)",
      "Bash(yes:*)", "Bash(timeout:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(:(){ :|:& };:)",
      "Bash(dd if=/dev/zero of=/dev/sda*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/session-bootstrap.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/auto-recall.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/local-recall.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/correction-detector.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/block-dangerous.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/protect-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/activity-logger.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/review-reminder.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/flush-to-openviking.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/compact-notify.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/write-handoff.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/auto-capture.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/close-heartbeat.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
